# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/xeno_db?schema=public"

# JWT Secrets (Generate secure random secrets in production)
JWT_ACCESS_SECRET="super-secret-jwt-access-key-minimum-32-characters"
JWT_REFRESH_SECRET="super-secret-jwt-refresh-key-minimum-32-characters"

# Email SMTP Server Configuration
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="smtp-username"
SMTP_PASS="smtp-password"
SMTP_FROM="noreply@xeno-saas.com"

# CORS Origin for Frontend
CORS_ORIGIN="http://localhost:3000"
